PORT=5000
AUTH_SECRET=change-me-to-a-long-random-string

# Postgres database (Neon / Vercel Postgres / Supabase / local)
# Required on Vercel so signups and feedback persist across serverless instances.
# Free option: https://neon.tech → create project → copy connection string
DATABASE_URL=
# Optional: force SSL on/off (default: SSL for remote hosts, off for localhost)
# DATABASE_SSL=true

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# PayPal subscriptions — use LIVE credentials from https://developer.paypal.com/dashboard/applications/live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live
